# ===========================================
# Travelist 環境変数
# ===========================================
# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env

# -------------------------------------------
# Server
# -------------------------------------------
# API サーバーのポート番号（デフォルト: 8080）
PORT=8080

# フロントエンドの静的ファイルディレクトリ（本番モードのみ）
# 開発時は設定不要。本番デプロイ時に指定する。
# STATIC_DIR=/app/dist

# -------------------------------------------
# Google Places API
# -------------------------------------------
# 取得方法:
#   1. Google Cloud Console (https://console.cloud.google.com/) にアクセス
#   2. プロジェクトを作成（または既存のプロジェクトを選択）
#   3. 「APIとサービス」→「ライブラリ」→「Places API (New)」を有効化
#   4. 「APIとサービス」→「認証情報」→「認証情報を作成」→「APIキー」
#   5. 作成されたAPIキーを制限設定（Places API のみに制限を推奨）
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# -------------------------------------------
# Anthropic Claude API
# -------------------------------------------
# 取得方法:
#   1. Anthropic Console (https://console.anthropic.com/) にアクセス
#   2. アカウントを作成 / ログイン
#   3. 「API Keys」→「Create Key」で新しいキーを発行
#   4. 発行されたキー（sk-ant-... 形式）をコピー
LLM_API_KEY=your_anthropic_api_key_here
