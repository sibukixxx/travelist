# ===========================================
# Travelist 環境変数
# ===========================================
# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env

# -------------------------------------------
# Server
# -------------------------------------------
# API サーバーのポート番号（デフォルト: 8080）
PORT=8080

# SQLite データベースのパス（デフォルト: ./data/travelist.db）
# テスト時は :memory: を指定可能
DB_PATH=./data/travelist.db

# フロントエンドの静的ファイルディレクトリ（本番モードのみ）
# 開発時は設定不要。本番デプロイ時に指定する。
# STATIC_DIR=/app/dist

# -------------------------------------------
# Google Places API
# -------------------------------------------
# 取得方法:
#   1. Google Cloud Console (https://console.cloud.google.com/) にアクセス
#   2. プロジェクトを作成（または既存のプロジェクトを選択）
#   3. 「APIとサービス」→「ライブラリ」→「Places API (New)」を有効化
#   4. 「APIとサービス」→「認証情報」→「認証情報を作成」→「APIキー」
#   5. 作成されたAPIキーを制限設定（Places API のみに制限を推奨）
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# -------------------------------------------
# LLM Provider
# -------------------------------------------
# 使用する LLM プロバイダを指定（デフォルト: stub）
# 対応プロバイダ: stub, anthropic, gemini
LLM_PROVIDER=stub

# -------------------------------------------
# LLM API Key
# -------------------------------------------
# LLM_PROVIDER に応じた API キーを設定
#
# anthropic の場合:
#   1. Anthropic Console (https://console.anthropic.com/) にアクセス
#   2. 「API Keys」→「Create Key」で発行（sk-ant-... 形式）
#
# gemini の場合:
#   1. Google AI Studio (https://aistudio.google.com/) にアクセス
#   2. 「Get API key」→「Create API key」で発行
LLM_API_KEY=your_llm_api_key_here
